<resources>

    <style name="Theme.CloudAlbum.Flat" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/ca_primary</item>
        <item name="colorPrimaryDark">@color/ca_primary_dark</item>
        <item name="colorAccent">@color/ca_primary</item>
        <item name="android:windowBackground">@color/ca_background</item>
        <item name="android:textColorPrimary">@color/ca_text_primary</item>
        <item name="android:textColorSecondary">@color/ca_text_secondary</item>
        <item name="android:buttonStyle">@style/Widget.CloudAlbum.Button</item>
        <item name="android:editTextStyle">@style/Widget.CloudAlbum.EditText</item>
    </style>

    <style name="Widget.CloudAlbum.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/ca_primary_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.CloudAlbum.Button.Secondary" parent="Widget.CloudAlbum.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/ca_text_primary</item>
    </style>

    <style name="Widget.CloudAlbum.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_flat</item>
        <item name="android:textColor">@color/ca_text_primary</item>
        <item name="android:textColorHint">@color/ca_text_secondary</item>
        <item name="android:minHeight">@dimen/input_height</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="Theme.CloudAlbum.Dialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/ca_surface</item>
        <item name="android:textColorPrimary">@color/ca_text_primary</item>
        <item name="android:textColorSecondary">@color/ca_text_secondary</item>
        <item name="colorAccent">@color/ca_focus</item>
    </style>

</resources>
