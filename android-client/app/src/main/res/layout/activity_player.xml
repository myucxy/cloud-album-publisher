<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ca_background"
    android:keepScreenOn="true">

    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/playerDrawerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imageStage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="@color/ca_background"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imageStageNext"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:background="@color/ca_background"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <com.google.android.exoplayer2.ui.StyledPlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/ca_background"
            android:focusable="false"
            android:focusableInTouchMode="false"
            app:controller_layout_id="@null"
            app:resize_mode="fit"
            app:show_buffering="never"
            app:surface_type="texture_view"
            app:use_controller="false" />

        <TextView
            android:id="@+id/emptyStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_overlay"
            android:padding="16dp"
            android:text="@string/no_playable_content"
            android:textColor="@color/ca_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <ScrollView
        android:id="@+id/menuDrawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/ca_background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/deviceInfoPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_menu_panel"
                android:descendantFocusability="blocksDescendants"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/deviceSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_focus"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/currentMediaPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_menu_panel"
                android:descendantFocusability="blocksDescendants"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/distributionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mediaText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <Button
                android:id="@+id/refreshButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:nextFocusDown="@id/setupButton"
                android:text="@string/refresh" />

            <Button
                android:id="@+id/setupButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nextFocusUp="@id/refreshButton"
                android:text="@string/open_setup" />

            <LinearLayout
                android:id="@+id/appUpdatePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/appUpdateTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/appUpdateSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_text_secondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/appUpdateButton"
                    style="@style/Widget.CloudAlbum.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rotationPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/rotationTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/rotationSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/rotationOptionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mutePanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/muteTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/muteSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_text_secondary"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/muteToggleCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/playbackSelectionPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/playbackSelectionTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/playbackSelectionSummaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ca_text_secondary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/playbackSelectionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <Button
                android:id="@+id/systemCapabilityButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:text="" />
        </LinearLayout>
    </ScrollView>

    </androidx.drawerlayout.widget.DrawerLayout>

    <FrameLayout
        android:id="@+id/drawerGestureHandle"
        android:layout_width="@dimen/drawer_handle_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:clickable="true"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <FrameLayout
        android:id="@+id/systemCapabilityOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_overlay"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/systemCapabilityPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/panel_padding">

            <TextView
                android:id="@+id/systemCapabilityTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ca_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/systemCapabilityScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:fadeScrollbars="false"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/systemCapabilityContentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ca_text_primary"
                    android:textSize="14sp" />
            </ScrollView>

            <Button
                android:id="@+id/systemCapabilityCloseButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
