<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/setupRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ca_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/ca_text_primary"
            android:textSize="@dimen/title_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/ca_text_secondary"
            android:textSize="@dimen/subtitle_size" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tv_hint"
            android:textColor="@color/ca_focus"
            android:textSize="@dimen/caption_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/panel_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/server_base_url"
                android:textColor="@color/ca_text_secondary"
                android:textSize="@dimen/label_size" />

            <EditText
                android:id="@+id/serverBaseUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/server_base_url_hint"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:singleLine="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/device_name"
                android:textColor="@color/ca_text_secondary"
                android:textSize="@dimen/label_size" />

            <EditText
                android:id="@+id/deviceNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/device_name_hint"
                android:imeOptions="actionDone"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/panel_padding">

            <TextView
                android:id="@+id/deviceUidText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />

            <TextView
                android:id="@+id/deviceTypeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />

            <TextView
                android:id="@+id/deviceModelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />

            <TextView
                android:id="@+id/deviceIdText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />

            <TextView
                android:id="@+id/activationStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/panel_padding">

            <TextView
                android:id="@+id/waitingHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="设备保存后会自动注册到服务器，等待后台在设备管理中绑定。绑定完成后可直接进入播放器。"
                android:textColor="@color/ca_text_secondary"
                android:textSize="@dimen/body_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="@dimen/panel_padding">

            <TextView
                android:id="@+id/setupStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_status_idle"
                android:textColor="@color/ca_text_primary"
                android:textSize="@dimen/body_size" />

            <TextView
                android:id="@+id/setupErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_error"
                android:textSize="@dimen/body_size"
                android:visibility="gone" />

            <TextView
                android:id="@+id/setupDetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/ca_text_secondary"
                android:textSize="@dimen/caption_size"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/saveButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/save_settings" />

            <Button
                android:id="@+id/playerButton"
                style="@style/Widget.CloudAlbum.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:text="@string/go_player" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
