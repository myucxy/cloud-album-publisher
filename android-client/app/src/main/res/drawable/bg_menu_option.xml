<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ca_surface_alt" />
            <stroke android:width="2dp" android:color="@color/ca_focus" />
            <corners android:radius="@dimen/panel_radius" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ca_surface" />
            <stroke android:width="1dp" android:color="@color/ca_focus" />
            <corners android:radius="@dimen/panel_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/ca_border" />
            <corners android:radius="@dimen/panel_radius" />
        </shape>
    </item>
</selector>
